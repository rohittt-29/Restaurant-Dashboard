# Copy this file to .env and fill in the values.
# Never commit .env (real secrets) — only commit .env.example.

# Backend API base URL (no trailing slash)
# Local dev:   http://localhost:3000
# Production:  https://restaurant-bot-eqiv.onrender.com
VITE_API_URL=https://restaurant-bot-eqiv.onrender.com

# Dashboard login password
# Set the real value in Vercel's Environment Variables UI for production.
VITE_DASHBOARD_PASSWORD=change-me
